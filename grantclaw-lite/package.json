{
  "name": "grantclaw-lite",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm --prefix server install && npm --prefix web install",
    "dev": "concurrently \"npm --prefix server run dev\" \"npm --prefix web run dev\"",
